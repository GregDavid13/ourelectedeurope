# The extracted security packages live on GitHub Packages, scoped to the
# repo owner. This maps the @gregdavid13 scope to that registry so a
# consuming product resolves @gregdavid13/* from GitHub Packages.
# (Inside THIS monorepo the same names resolve to the local workspace, so
# this only matters for clones installing the published versions.)
@gregdavid13:registry=https://npm.pkg.github.com

# Auth is intentionally NOT committed here (an active ${NODE_AUTH_TOKEN}
# line makes pnpm warn whenever the var is unset). Provide it out-of-band:
#   • CI: actions/setup-node with registry-url injects it from NODE_AUTH_TOKEN
#   • local: add to ~/.npmrc →  //npm.pkg.github.com/:_authToken=<PAT>
#     (a token with read:packages, or write:packages to publish)

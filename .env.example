# Copy this file to apps/web/.env (NOT the repo root — `next dev` runs
# with cwd in apps/web and only loads apps/web/.env*). Fill what you
# need: only the REQUIRED block must be set for the app to boot. Every
# integration below it is OPTIONAL and validated at its point of use —
# leave a section blank until you wire that feature (see lib/env.ts).
#
# To skip validation entirely during early local dev / CI:
#   SKIP_ENV_VALIDATION=1 pnpm --filter @ourelectedeurope/web dev

# ── REQUIRED: Supabase (app cannot run without these) ──────────
NEXT_PUBLIC_SUPABASE_URL=               # Project URL from dashboard
NEXT_PUBLIC_SUPABASE_ANON_KEY=          # Safe for browser and mobile

# ── OPTIONAL: Supabase service role (admin/audit/webhooks/cron) ─
SUPABASE_SERVICE_ROLE_KEY=              # Server-only. Never expose.

# ── OPTIONAL: Stripe (billing) ─────────────────────────────────
# No paid tiers ship in the scaffold. When you add one, define its
# price id here (e.g. STRIPE_PRICE_PRO=price_...) and a PLANS entry in
# packages/stripe/src/plans.ts.
STRIPE_SECRET_KEY=                      # sk_live_... — server only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=     # pk_live_... — safe for browser/mobile
STRIPE_WEBHOOK_SECRET=                  # whsec_... — from Stripe dashboard

# ── OPTIONAL: Security ─────────────────────────────────────────
CRON_SECRET=                            # openssl rand -hex 32 (cron routes fail closed if unset)
SUPER_ADMIN_EMAILS=                     # comma-separated
ENCRYPTION_KEY=                         # openssl rand -hex 32 (64 char hex = 32 bytes)

# ── OPTIONAL: Rate limiting (Upstash) ──────────────────────────
# If unset, rate limiting is disabled and fails open (requests allowed).
UPSTASH_REDIS_REST_URL=                 # from upstash.com dashboard
UPSTASH_REDIS_REST_TOKEN=               # from upstash.com dashboard

# ── OPTIONAL: Email (Resend) ───────────────────────────────────
RESEND_API_KEY=                         # re_...

# ── OPTIONAL: App ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=                    # https://www.yourdomain.com
